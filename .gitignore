# ---- Python Standard Ignores ----
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Jupyter checkpoints
.ipynb_checkpoints/

# OS files
.DS_Store
Thumbs.db

# Datasets (keep folder structure but ignore data files)
data/raw/*
data/processed/*
data/interim/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/interim/.gitkeep

# Large model files
*.h5
*.hdf5
*.ckpt
*.pth
*.pt
*.joblib
*.pkl
models/saved_models/*
!models/saved_models/.gitkeep

# Experiment logs
logs/
tensorboard/
wandb/
mlruns/

# Temporary/backup files
*.tmp
*.temp
*.bak